{
  "name": "@pokercrawl/training",
  "version": "0.1.0",
  "description": "PokerCrawl training engine — adaptive strategy learning, hand history, ELO ratings",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "pokercrawl-train": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "train": "node ./dist/index.js"
  },
  "dependencies": {
    "@pokercrawl/engine": "*",
    "@pokercrawl/mcp-server": "*",
    "@pokercrawl/agents": "*"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "@types/node": "^20.0.0"
  }
}
