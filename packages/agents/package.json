{
  "name": "@pokercrawl/agents",
  "version": "0.1.0",
  "description": "PokerCrawl AI agents — simulated bots and real Claude/GPT players",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "pokercrawl-demo": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "demo": "node --experimental-vm-modules dist/index.js"
  },
  "dependencies": {
    "@pokercrawl/engine": "*",
    "@pokercrawl/mcp-server": "*",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@anthropic-ai/sdk": "^0.32.0",
    "openai": "^4.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "@types/node": "^20.0.0"
  }
}
