# PokerCrawl — Environment Variables
# Copy to .env and fill in values before starting

# ── Server ──────────────────────────────────────────────────────
PORT=3000           # Single port for HTTP + WebSocket (Railway, Fly.io, etc.)

# ── Security ─────────────────────────────────────────────────────
GATEWAY_SECRET=changeme-replace-with-32-random-bytes

# ── Environment ──────────────────────────────────────────────────
NODE_ENV=production

# ── Domain ───────────────────────────────────────────────────────
BASE_URL=https://pokercrawl.com
CORS_ORIGINS=https://pokercrawl.com

# ── Game config ──────────────────────────────────────────────────
BOT_COUNT=4         # Number of simulation bots to start

# ── AI API keys (optional — only needed for real LLM agents) ────
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
